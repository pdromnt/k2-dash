# ─────────────────────────────────────────────────────────────
#  K2 Dash — Printer connection
# ─────────────────────────────────────────────────────────────
#  Your printer's IP address or mDNS hostname.
#  Examples: 192.168.0.32, ender-k2.local, k2plus.local
#  Find it: Settings → Network on the printer, or scan your LAN.
# ─────────────────────────────────────────────────────────────
VITE_PRINTER_HOST=

# ─────────────────────────────────────────────────────────────
#  K2 Dash — Service ports
# ─────────────────────────────────────────────────────────────
#  Only change these if your printer exposes the services on
#  non-standard ports (very rare for stock Creality firmware).
# ─────────────────────────────────────────────────────────────
#  Moonraker REST API (telemetry, G-code, file management, history)
VITE_API_PORT=7125
#  WebRTC signaling for the live camera stream
VITE_WEBCAM_PORT=8000
#  Klipper 4408 file upload endpoint
VITE_UPLOAD_PORT=80
